#!/usr/bin/env bash
# Orkestra CLI entrypoint.
set -euo pipefail

# Resolve real path of this script (handles symlinks).
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ORK_HOME="$(cd -P "$(dirname "$SOURCE")/.." >/dev/null 2>&1 && pwd)"
export ORK_HOME

# shellcheck source=../lib/ui/colors.sh
source "$ORK_HOME/lib/ui/colors.sh"
# shellcheck source=../lib/ui/menu.sh
source "$ORK_HOME/lib/ui/menu.sh"
# shellcheck source=../lib/core/paths.sh
source "$ORK_HOME/lib/core/paths.sh"
# shellcheck source=../lib/core/manifest.sh
source "$ORK_HOME/lib/core/manifest.sh"
# shellcheck source=../lib/core/entities.sh
source "$ORK_HOME/lib/core/entities.sh"

usage() {
    cat <<EOF
${ORK_BOLD}orkestra${ORK_NC} — orchestrate AI coding-agent guidance for any project

${ORK_BOLD}USAGE${ORK_NC}
  orkestra                           interactive top-level menu
  orkestra <command> [options]

${ORK_BOLD}COMMANDS${ORK_NC}
  init        scaffold .orkestra/ + agent files in a project
  render      re-render agent files from current sources
  webui       run the local plugin manager WebUI
  ui          alias for webui
  list        list plugins|templates|agents
  enable      install a plugin into a scope
  disable     remove a plugin from a scope
  status      show active scope and installed plugins
  add-agent   enable an agent in the current project
  remove-agent disable an agent in the current project
  add-template scaffold a new template in your user dir
  update      pull latest distribution and re-render
  suggest     diff a remote markdown URL against current sources
  hooks       manage quality hooks
  mcp         run Orkestra MCP server (stdio)
  doctor      check installation & project health
  version     print version

${ORK_BOLD}GLOBAL FLAGS${ORK_NC}
  -y, --yes        auto-confirm prompts
      --quiet      minimal output
      --dry-run    show what would change without writing
  -h, --help       show this help

${ORK_DIM}docs: $ORK_HOME/ARCHITECTURE.md${ORK_NC}
EOF
}

# Parse global flags before the subcommand.
ORK_DRY_RUN=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        -y|--yes)    export ORK_YES=1; shift ;;
        --quiet)     export ORK_QUIET=1; shift ;;
        --dry-run)   export ORK_DRY_RUN=1; shift ;;
        -h|--help)   usage; exit 0 ;;
        --)          shift; break ;;
        -*)          break ;;  # let subcommand parse it
        *)           break ;;
    esac
done

cmd="${1:-}"
shift || true

interactive_menu() {
    ork_header "Orkestra v$ORK_VERSION"
    local choice
    ork_menu "What do you want to do?" choice \
        "Open plugin manager WebUI" \
        "Install plugin in this project" \
        "Remove plugin from this project" \
        "Install plugin for this user" \
        "Remove plugin from this user" \
        "Show installed plugins" \
        "Initialize or deploy project template" \
        "Re-render project agent files" \
        "Manage quality hooks" \
        "Run doctor checks" \
        "Quit" || exit 0
    case "$choice" in
        "Open plugin manager WebUI") exec "$0" webui ;;
        "Install plugin in this project") interactive_plugin_scope enable project ;;
        "Remove plugin from this project") interactive_plugin_scope disable project ;;
        "Install plugin for this user") interactive_plugin_scope enable global ;;
        "Remove plugin from this user") interactive_plugin_scope disable global ;;
        "Show installed plugins") interactive_status ;;
        "Initialize or deploy project template") exec "$0" init ;;
        "Re-render project agent files") exec "$0" render ;;
        "Manage quality hooks") exec "$0" hooks ;;
        "Run doctor checks") exec "$0" doctor ;;
        *) exit 0 ;;
    esac
}

interactive_status() {
    local scope_label scope
    ork_menu "Which scope?" scope_label "Project" "User" || exit 0
    [[ "$scope_label" == "User" ]] && scope="global" || scope="project"
    exec "$0" status --scope "$scope"
}

interactive_plugin_scope() {
    local action="$1" scope="$2"
    local prompt entity
    [[ "$action" == "enable" ]] && prompt="Pick a plugin to install" || prompt="Pick a plugin to remove"
    if [[ "$action" == "enable" ]]; then
        interactive_pick_entity "$prompt" entity || exit 0
    else
        interactive_pick_installed_entity "$prompt" "$scope" entity || exit 0
    fi

    if [[ "$action" == "enable" ]]; then
        local agents_csv
        interactive_pick_agents_csv "$scope" agents_csv || exit 0
        if [[ -n "$agents_csv" ]]; then
            exec "$0" enable "$entity" --scope "$scope" --agents "$agents_csv"
        fi
        exec "$0" enable "$entity" --scope "$scope"
    fi

    exec "$0" disable "$entity" --scope "$scope"
}

interactive_pick_entity() {
    local prompt="$1" outvar="$2"
    local entities=()
    local id
    while IFS= read -r id; do
        [[ -n "$id" ]] && entities+=("$id")
    done < <(ork_list_entities)
    [[ ${#entities[@]} -gt 0 ]] || ork_die "No plugins found"

    local selected
    ork_menu "$prompt" selected "${entities[@]}" || return 130
    printf -v "$outvar" "%s" "$selected"
}

interactive_pick_installed_entity() {
    local prompt="$1" scope="$2" outvar="$3"
    local project entities_dir installed=()
    project="$(pwd)"
    entities_dir="$(ork_entities_install_dir "$scope" "$project")"
    if [[ -d "$entities_dir" ]]; then
        local file rel id
        while IFS= read -r file; do
            rel="${file#$entities_dir/}"
            id="${rel%.md}"
            id="${id//\//.}"
            [[ -n "$id" ]] && installed+=("$id")
        done < <(find "$entities_dir" -type f -name "*.md" | sort)
    fi
    [[ ${#installed[@]} -gt 0 ]] || ork_die "No plugins installed in $scope scope"

    local selected
    ork_menu "$prompt" selected "${installed[@]}" || return 130
    printf -v "$outvar" "%s" "$selected"
}

interactive_pick_agents_csv() {
    local scope="$1" outvar="$2"
    local agents=()
    local agent
    if [[ "$scope" == "project" && -f ".orkestra/manifest.yaml" ]]; then
        while IFS= read -r agent; do
            [[ -n "$agent" ]] && agents+=("$agent")
        done < <(awk '
            /^agents:/ { in_agents=1; next }
            in_agents && /^[[:space:]]+-[[:space:]]+/ { sub(/^[[:space:]]+-[[:space:]]+/, ""); print; next }
            in_agents && /^[^[:space:]]/ { in_agents=0 }
        ' ".orkestra/manifest.yaml")
    else
        while IFS= read -r agent; do
            [[ -n "$agent" && "$agent" != "generic" ]] && agents+=("$agent")
        done < <(ork_list_agents)
        local selected
        ork_multiselect "Apply plugin hook files for which agents?" selected "${agents[@]}" || return 130
        agents=()
        while IFS= read -r agent; do
            [[ -n "$agent" ]] && agents+=("$agent")
        done <<< "$selected"
        [[ ${#agents[@]} -gt 0 ]] || ork_die "Select at least one agent"
    fi

    local csv="" sep=""
    for agent in "${agents[@]}"; do
        csv+="$sep$agent"
        sep=","
    done
    printf -v "$outvar" "%s" "$csv"
}

case "$cmd" in
    "")        interactive_menu ;;
    init)      "$ORK_HOME/lib/cli/init.sh"      "$@" ;;
    render)    "$ORK_HOME/lib/cli/render.sh"    "$@" ;;
    list)      "$ORK_HOME/lib/cli/list.sh"      "$@" ;;
    add-agent) "$ORK_HOME/lib/cli/add-agent.sh" "$@" ;;
    remove-agent) "$ORK_HOME/lib/cli/remove-agent.sh" "$@" ;;
    add-template) "$ORK_HOME/lib/cli/add-template.sh" "$@" ;;
    update)    "$ORK_HOME/lib/cli/update.sh"    "$@" ;;
    suggest)   "$ORK_HOME/lib/cli/suggest.sh"   "$@" ;;
    hooks)     "$ORK_HOME/lib/cli/hooks.sh"     "$@" ;;
    mcp)       "$ORK_HOME/lib/cli/mcp.sh"       "$@" ;;
    webui|ui)  "$ORK_HOME/lib/cli/webui.sh"     "$@" ;;
    enable)    "$ORK_HOME/lib/cli/enable.sh"    "$@" ;;
    disable)   "$ORK_HOME/lib/cli/disable.sh"   "$@" ;;
    status)    "$ORK_HOME/lib/cli/status.sh"    "$@" ;;
    doctor)    "$ORK_HOME/lib/cli/doctor.sh"    "$@" ;;
    version|-v|--version) printf "orkestra %s\n" "$ORK_VERSION" ;;
    help|-h|--help) usage ;;
    *)
        ork_error "Unknown command: $cmd"
        usage
        exit 1
        ;;
esac
